# Copy to `.env.local` in this folder (`cp .env.example .env.local`).
# Next.js only loads `.env*` from `web/`, and only `NEXT_PUBLIC_*` is available in the browser.

# Same address as `CONTRACT_ADDRESS` in the repo-root `.env`
NEXT_PUBLIC_CONTRACT_ADDRESS=

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_CHAIN_ID=11155111

# Optional; same as root `RPC_URL` if you want a public Sepolia HTTP endpoint in the app
# NEXT_PUBLIC_RPC_URL=
