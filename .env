# Copy to .env and fill in values. Do not commit .env.

# --- Web (Next.js) ---
# Sepolia RPC (e.g. https://rpc.sepolia.org or Alchemy/Infura URL)
NEXT_PUBLIC_RPC_URL=
# Deployed contract address (after first deploy)
NEXT_PUBLIC_CONTRACT_ADDRESS=
# Sepolia chain ID
NEXT_PUBLIC_CHAIN_ID=11155111

# --- Oracle (Python) ---
# Sports data API key (provider-specific)
SPORTS_API_KEY=4d01d8631bc3e845cfa2b57b8d40cdb60e2f8e77681196c770ca7dcdf9e15552
# Sepolia RPC for sending reportResult tx
RPC_URL=
# Private key for the oracle (only this key can call reportResult)
ORACLE_PRIVATE_KEY=
# Deployed contract address
CONTRACT_ADDRESS=

# --- Contracts (deploy/verify) ---
# Sepolia RPC for deployment
SEPOLIA_RPC_URL=
# Deployer private key (do not use a key with mainnet funds)
PRIVATE_KEY=
# Etherscan API key for contract verification on Sepolia
ETHERSCAN_API_KEY=
